import boto3
import time

def get_instance_state(instance_id, ec2_client):
    response = ec2_client.describe_instances(InstanceIds=[instance_id])
    state = response['Reservations'][0]['Instances'][0]['State']['Name']
    return state

def get_public_ip(instance_id, ec2_client):
    response = ec2_client.describe_instances(InstanceIds=[instance_id])
    instance = response['Reservations'][0]['Instances'][0]
    return instance.get('PublicIpAddress')

def wait_until_running(instance_id, ec2_client):
    print("Waiting for instance to reach 'running' state...")
    while True:
        state = get_instance_state(instance_id, ec2_client)
        if state == 'running':
            break
        time.sleep(5)
    print("Instance is running.")

def start_stop_instance(instance_id, ec2_client):
    current_state = get_instance_state(instance_id, ec2_client)

    if current_state == 'running':
        print(f"Instance {instance_id} is already running. Stopping it.")
        ec2_client.stop_instances(InstanceIds=[instance_id])

    elif current_state == 'stopped':
        print(f"Instance {instance_id} is stopped. Starting it.")
        ec2_client.start_instances(InstanceIds=[instance_id])

        # Wait until running
        wait_until_running(instance_id, ec2_client)

        # Fetch and print public IP
        public_ip = get_public_ip(instance_id, ec2_client)
        print(f"Instance Public IP: {public_ip}")

    else:
        print(f"Instance {instance_id} is in an unexpected state: {current_state}")


if __name__ == "__main__":
